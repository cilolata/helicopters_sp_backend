generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Aircraft {
  icao_hex      String   @id @db.VarChar(6)
  first_seen    DateTime @db.Timestamptz(6)
  last_seen     DateTime @db.Timestamptz(6)
  last_callsign String?  @db.VarChar(10)
  last_squawk   String?  @db.VarChar(4)
  operator      String?  @db.VarChar(200)
  owner         String?  @db.VarChar(200)
  model         String?  @db.VarChar(100)

  @@index([last_seen(sort: Desc)])
  @@map("aircraft")
}

model Position {
  id          Int      @id @default(autoincrement())
  icao_hex    String   @db.VarChar(6)
  lat         Float
  lon         Float
  altitude    Int?
  captured_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([icao_hex, captured_at(sort: Desc)])
  @@map("positions")
}

model AnacRegistry {
  registration String  @id @db.VarChar(8)
  owner        String? @db.VarChar(300)
  model        String? @db.VarChar(100)
  operator     String? @db.VarChar(300)

  @@map("anac_registry")
}

model DailyFlight {
  id          Int      @id @default(autoincrement())
  icao_hex    String   @db.VarChar(6)
  flight_date String   @db.VarChar(10)
  first_seen  DateTime @db.Timestamptz(6)
  last_seen   DateTime @db.Timestamptz(6)
  last_lat    Float?
  last_lon    Float?
  last_alt    Int?

  @@index([icao_hex, flight_date, last_seen(sort: Desc)])
  @@index([flight_date])
  @@map("daily_flights")
}

